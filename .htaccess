  RewriteRule ^male-infertility-symptoms-causes-treatment/?$ /english/male-infertility-symptoms-causes-treatment/ [R=301,L,NC]
  RewriteRule ^how-lifestyle-affects-fertility-what-you-can/?$ /english/how-lifestyle-affects-fertility-what-you-can/ [R=301,L,NC]
  RewriteRule ^ivf-journey-process-essential-tips-dos-donts/?$ /english/ivf-journey-process-essential-tips-dos-donts/ [R=301,L,NC]
  RewriteRule ^choosing-the-right-ivf-specialist/?$ /english/choosing-the-right-ivf-specialist/ [R=301,L,NC]
  RewriteRule ^affordable-ivf-cost/?$ /english/affordable-ivf-cost/ [R=301,L,NC]
  RewriteRule ^advancing-parenthood-at-premier-icsi-centres/?$ /english/advancing-parenthood-at-premier-icsi-centres/ [R=301,L,NC]
  RewriteRule ^health-in-fertility-treatments/?$ /english/health-in-fertility-treatments/ [R=301,L,NC]
  RewriteRule ^understanding-the-impact-of-icsi-on-art-success/?$ /english/understanding-the-impact-of-icsi-on-art-success/ [R=301,L,NC]
  RewriteRule ^miscarriage-journey-from-coping-healing/?$ /english/miscarriage-journey-from-coping-healing/ [R=301,L,NC]
  RewriteRule ^how-lifestyle-affects-fertility-what-you-can-do-to-improve-your-chances/?$ /english/how-lifestyle-affects-fertility-what-you-can-do-to-improve-your-chances/ [R=301,L,NC]
  RewriteRule ^pcos-symptoms-treatment-and-fertility/?$ /english/pcos-symptoms-treatment-and-fertility/ [R=301,L,NC]
  RewriteRule ^shighrapatan-ke-upay-lakshan-aur-ilaaj/?$ /hindi/shighrapatan-ke-upay-lakshan-aur-ilaaj/ [R=301,L,NC]
  RewriteRule ^kam-shukranu-sankhya-kaaran-lakshan-aur-upchaar/?$ /hindi/kam-shukranu-sankhya-kaaran-lakshan-aur-upchaar/ [R=301,L,NC]
  RewriteRule ^so-you-have-completed-your-covid-vaccination/?$ /blogs/fertility/ [R=301,L,NC]
  RewriteRule ^what-is-prp-treatment-in-ivf/?$ /english/what-is-prp-treatment-in-ivf/ [R=301,L,NC]
  RewriteRule ^understanding-the-basics-of-fertility/?$ /english/understanding-the-basics-of-fertility/ [R=301,L,NC]
  RewriteRule ^can-i-pill-cause-infertility-in-women/?$ /english/can-i-pill-cause-infertility-in-women/ [R=301,L,NC]
  RewriteRule ^poor-egg-quality-and-fertility/?$ /english/poor-egg-quality-and-fertility/ [R=301,L,NC]
  RewriteRule ^thyroid-impacts-pregnancy-and-ivf-success/?$ /english/thyroid-impacts-pregnancy-and-ivf-success/ [R=301,L,NC]
  
  # Allow only safe HTTP methods
  RewriteCond %{REQUEST_METHOD} !^(GET|POST|HEAD|OPTIONS)$ [NC]
  RewriteRule .* - [F,L]

  # Block direct access to sensitive files and directories
  RewriteRule (^|/)\.(env|git|svn|htaccess) - [F,L,NC]
  RewriteRule (^|/)(package(-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|composer\.(json|lock)|README\.md|HOSTING_GUIDE\.md|ROUTE_MIGRATION_SUMMARY\.md)$ - [F,L,NC]
  RewriteRule (^|/)(node_modules|\.next|scripts|\.cursor|\.vscode|vendor)/ - [F,L,NC]
  
  # Redirect to index.html for client-side routing
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Disable directory listing
Options -Indexes

# MIME sniffing and file upload abuse protection
<IfModule mod_mime.c>
  RemoveType .php .phtml .php3 .php4 .php5 .phps .cgi .pl .py .jsp .asp .aspx .sh
</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Permissions-Policy "accelerometer=(), autoplay=(self), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' https://www.youtube.com https://www.youtube-nocookie.com https://www.googletagmanager.com https://connect.facebook.net https://googleads.g.doubleclick.net https://a.quora.com; script-src-elem 'self' 'unsafe-inline' https://www.youtube.com https://www.youtube-nocookie.com https://www.googletagmanager.com https://connect.facebook.net https://googleads.g.doubleclick.net https://a.quora.com; style-src 'self' 'unsafe-inline' https://fonts.cdnfonts.com https://fonts.googleapis.com; img-src 'self' data: blob: https://img.youtube.com https://i.ytimg.com https://www.facebook.com https://www.google.com https://www.google.co.in https://googleads.g.doubleclick.net https://www.googletagmanager.com https://q.quora.com; font-src 'self' data: https://fonts.cdnfonts.com https://fonts.gstatic.com; connect-src 'self' https://soi.seedsofinnocens.com https://www.youtube.com https://www.youtube-nocookie.com https://www.googletagmanager.com https://www.google-analytics.com https://analytics.google.com https://www.google.com https://www.google.co.in https://googleads.g.doubleclick.net https://www.googleadservices.com https://www.facebook.com; media-src 'self' blob:; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; upgrade-insecure-requests"

  # Enforce HTTPS transport (active only on HTTPS)
  Header always set Strict-Transport-Security "max-age=31536000" env=HTTPS
</IfModule>

# Enable compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Prefer Brotli where available (better compression than gzip)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 5 minutes"
</IfModule>

# Strong immutable caching for hashed/static assets
<IfModule mod_headers.c>
  <FilesMatch "\.(?:js|css|woff2?|svg|jpg|jpeg|png|gif|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
